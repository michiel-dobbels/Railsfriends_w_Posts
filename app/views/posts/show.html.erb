<div class="container mt-4">
  <div class="card shadow-sm mb-4">
    <div class="card-body">
    <h6 class="card-subtitle mb-2 text-muted">
    <%= @post.user&.email || "Unknown user" %>


  </h6>
      <p class="card-text fs-5"><%= @post.content %></p>
    </div>
  </div>

  <h4 class="fw-bold text-success">Comments</h4>

  <div class="card shadow-sm p-4 mb-4">
    <%= form_with url: post_comments_path(@post), local: true do |form| %>
      <div class="mb-3">
        <%= form.text_area :content, class: "form-control", rows: 3, placeholder: "Reply to this post..." %>
      </div>
      <%= form.submit "Comment", class: "btn btn-success fw-semibold" %>
    <% end %>
  </div>

  <% @post.comments.each do |comment| %>
    <div class="card mb-3 shadow-sm">
      <div class="card-body">
        <h6 class="card-subtitle mb-2 text-muted"><%= comment.user.email %></h6>
        <p class="card-text"><%= comment.content %></p>
      </div>
    </div>
  <% end %>

  <%= link_to "Back to Posts", posts_path, class: "btn btn-outline-success mt-3 fw-semibold" %>
</div>
