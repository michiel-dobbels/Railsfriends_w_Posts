<div class="container mt-4">
  <h1 class="mb-4 fw-bold text-success">All Posts</h1>

  <div class="mb-4">
    <%= link_to "New Post", new_post_path, class: "btn btn-success fw-semibold" %>
  </div>

  <% @posts.each do |post| %>
   <%= link_to post_path(post), class: "text-decoration-none text-dark" do %>
  <div class="card mb-3 shadow-sm">
    <div class="card-body">
      <h6 class="card-subtitle mb-2 text-muted">
        <%= post.user&.email || "Unknown user" %>
      </h6>
      <p class="text-muted small">
        <%= time_ago_in_words(post.created_at) %> ago
      </p>
      <p class="card-text fs-5"><%= post.content %></p>
    </div>
  </div>
<% end %>

  <% end %>
</div>
